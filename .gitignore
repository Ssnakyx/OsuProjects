# ── Python ──
.venv/
__pycache__/
*.pyc
*.egg-info/
.mypy_cache/
.pytest_cache/

# ── OS / editor cruft ──
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/

# ── Claude Code local stuff (personal, not for the repo) ──
.claude/settings.local.json

# ── Test fixtures (generated by tests/make_fixtures.py) ──
tests/fixtures/

# ── Beatmaps & downloaded map cache ──
# Maps auto-download to ~/.osu-replay-viewer; ignore any that land in the repo.
*.osz
.osu-replay-viewer/

# ── Skins (picked up automatically, too big for the repo) ──
# Put your .osk in the project root locally.
*.osk

# ── Personal replays — never commit your own .osr files ──
*.osr

# ── Local debug screenshots / scratch images ──
*.png
